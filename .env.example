# Copy to .env.local and fill in. .env.local is gitignored.
# Never commit real values.

# Anthropic (Opus 4.7 + Managed Agents beta)
ANTHROPIC_API_KEY=

# GitHub (fine-grained PAT, public-repo read)
GITHUB_TOKEN=

# Backend
FRONTEND_ORIGIN=http://localhost:3000
ENVIRONMENT=development

# Required for any public deploy: shared token that gates POST /api/ingest.
# Unset = endpoint is open (fine for local dev only).
# INGEST_AUTH_TOKEN=set-a-random-32-char-string-here

# Optional: comma-separated allowlist of repos the ingest endpoint accepts.
# Unset = any public repo is allowed.
# INGEST_ALLOWED_REPOS=pmndrs/zustand,honojs/hono,shadcn-ui/ui

# Frontend (NEXT_PUBLIC_* rides the browser bundle)
# NEXT_PUBLIC_INGEST_TOKEN=must-match-backend-INGEST_AUTH_TOKEN
